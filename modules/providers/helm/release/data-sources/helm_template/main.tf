data "helm_template" "this" {
  count                      = var.enabled ? 1 : 0
  chart                      = var.chart
  name                       = var.name
  api_versions               = var.api_versions
  atomic                     = var.atomic
  crds                       = var.crds
  create_namespace           = var.create_namespace
  dependency_update          = var.dependency_update
  description                = var.description
  devel                      = var.devel
  disable_openapi_validation = var.disable_openapi_validation
  disable_webhooks           = var.disable_webhooks
  include_crds               = var.include_crds
  is_upgrade                 = var.is_upgrade
  keyring                    = var.keyring
  kube_version               = var.kube_version
  manifest                   = var.manifest
  manifests                  = var.manifests
  namespace                  = var.namespace
  notes                      = var.notes
  pass_credentials           = var.pass_credentials
  postrender                 = var.postrender
  render_subchart_notes      = var.render_subchart_notes
  replace                    = var.replace
  repository                 = var.repository
  repository_ca_file         = var.repository_ca_file
  repository_cert_file       = var.repository_cert_file
  repository_key_file        = var.repository_key_file
  repository_password        = var.repository_password
  repository_username        = var.repository_username
  reset_values               = var.reset_values
  reuse_values               = var.reuse_values
  set                        = var.set
  set_list                   = var.set_list
  set_sensitive              = var.set_sensitive
  set_wo                     = var.set_wo
  show_only                  = var.show_only
  skip_crds                  = var.skip_crds
  skip_tests                 = var.skip_tests
  timeout                    = var.timeout
  timeouts                   = var.timeouts
  validate                   = var.validate
  values                     = var.values
  verify                     = var.verify
  version                    = var.version
  wait                       = var.wait
}
