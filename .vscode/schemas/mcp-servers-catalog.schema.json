{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://template-mechanics.dev/schemas/mcp-servers-catalog.schema.json",
  "title": "MCP Servers Catalog",
  "type": "object",
  "required": [
    "version",
    "defaults",
    "servers",
    "routing"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "defaults": {
      "type": "object",
      "required": [
        "transport",
        "disabled"
      ],
      "properties": {
        "transport": {
          "type": "string",
          "enum": [
            "stdio"
          ]
        },
        "disabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "servers": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
          "type": "object",
          "required": [
            "displayName",
            "description",
            "transport",
            "providersRequired",
            "package",
            "version"
          ],
          "properties": {
            "displayName": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "transport": {
              "type": "string",
              "enum": [
                "stdio"
              ]
            },
            "alwaysEnabled": {
              "type": "boolean"
            },
            "providersRequired": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "package": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "routing": {
      "type": "object",
      "required": [
        "byProvider"
      ],
      "properties": {
        "byProvider": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z][A-Za-z0-9_-]*$": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
