# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Plan files (may contain sensitive data)
*.tfplan
*.tfplan.*
tfplan
tfplan.json
tfdestroy.plan
provider-schema.json
*.tfplan.applied-*
*.plan.applied-*

# Variable files that may contain secrets
*.auto.tfvars
*.auto.tfvars.json
secrets.tfvars
secrets.auto.tfvars
*.local.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# State backups
*.backup
**/.state-backups/

# Terraform Cloud / HCP credentials
.terraform.d/

# Pester test results
test-results.xml

# Editor / OS junk
.DS_Store
Thumbs.db
.idea/
*.swp

# Local secrets / env
.env
.env.local

# Local tool cache
.tools/

# Helm cache directories created by harness plan/apply/destroy isolation
# (Invoke-TerraformPlan.ps1, Invoke-TerraformApply.ps1, Invoke-TerraformDestroy.ps1
#  set HELM_REPOSITORY_CACHE/CONFIG to <workspace>/.helm/ to avoid polluting
#  the global ~/.helm. These dirs must not be committed.)
**/.helm/
