# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Plan files (may contain sensitive data)
*.tfplan
*.tfplan.*
tfplan
tfplan.json

# Variable files that may contain secrets
*.auto.tfvars
*.auto.tfvars.json
secrets.tfvars
secrets.auto.tfvars
*.local.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# State backups
*.backup

# Terraform Cloud / HCP credentials
.terraform.d/

# Pester test results
test-results.xml

# Editor / OS junk
.DS_Store
Thumbs.db
.idea/
*.swp

# Local secrets / env
.env
.env.local

# Local tool cache
.tools/
